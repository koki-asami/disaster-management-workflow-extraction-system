{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:CreateBucket",
        "s3:HeadBucket",
        "s3:HeadObject"
      ],
      "Resource": [
        "arn:aws:s3:::dmwe-pdfs-dev",
        "arn:aws:s3:::dmwe-pdfs-dev/*",
        "arn:aws:s3:::dmwe-pdfs-prod",
        "arn:aws:s3:::dmwe-pdfs-prod/*",
        "arn:aws:s3:::disaster-management-pdfs",
        "arn:aws:s3:::disaster-management-pdfs/*"
      ]
    }
  ]
}
